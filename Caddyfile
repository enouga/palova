# Reverse-proxy + HTTPS automatique (Let's Encrypt) pour Palova.
# Caddy résout les noms `frontend` / `backend` via le réseau interne Docker.
# Multi-domaines : palova.fr ET palova.app servent l'app. L'API reste partagée
# sur api.palova.fr (auth par token Bearer → cross-origin OK), donc PAS de
# bloc api.palova.app.

{
	email admin@palova.fr
	# Certificats « à la demande » pour les sous-domaines clubs : Caddy demande au backend
	# si le domaine est autorisé avant d'émettre un certificat.
	on_demand_tls {
		ask http://backend:3001/internal/tls-check
	}
}

# Compression des réponses (ni Express ni Next côté backend API n'en font) : ~5× de
# bande passante en moins sur le JSON de la grille Réserver, martelée au rush de minuit.
# Liste de types EXPLICITE, sans text/event-stream : les 4 canaux SSE traversent le
# proxy sans compresseur intermédiaire (zéro risque de buffering des événements).
(compress) {
	encode {
		zstd
		gzip
		match {
			header Content-Type application/json*
			header Content-Type text/html*
			header Content-Type text/css*
			header Content-Type text/plain*
			header Content-Type application/javascript*
			header Content-Type image/svg+xml*
		}
	}
}

# Plateforme (apex des deux domaines) → frontend. Un apex ne matche PAS le wildcard
# *.<domaine>, donc pas de chevauchement : certificat managé classique.
palova.fr, palova.app {
	import compress
	reverse_proxy frontend:3000
}

# API → backend (uniquement sur .fr — endpoint partagé). on_demand explicite :
# api.palova.fr matche aussi *.palova.fr, il faut une politique TLS COHÉRENTE avec
# le wildcard, sinon Caddy mélange « managé » et « on-demand » sur le même nom et
# refuse le handshake (alert 80).
api.palova.fr {
	tls {
		on_demand
	}
	import compress
	reverse_proxy backend:3001
}

# www + sous-domaines clubs (<slug>.palova.fr / <slug>.palova.app) → frontend,
# certificat à la demande. www est volontairement retiré du bloc apex pour qu'il
# soit géré ici en on_demand (même résultat : il route vers le frontend) et n'entre
# plus en conflit.
*.palova.fr, *.palova.app {
	tls {
		on_demand
	}
	import compress
	reverse_proxy frontend:3000
}
