# Secrets de production — copier ce fichier en `.env.prod` (NON versionné) et remplir.
# Utilisé par docker-compose.prod.yml :
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# Mot de passe de la base Postgres (choisis une chaîne forte).
POSTGRES_PASSWORD=change-moi-mot-de-passe-postgres-fort

# Clé de signature des JWT (longue chaîne aléatoire).
# Générer p.ex. avec :  openssl rand -hex 48
JWT_SECRET=change-moi-longue-chaine-aleatoire

# Verrou d'accès privé (Basic Auth) — pop-up login sur tout le site.
# Laisser ces 2 variables pour garder le site privé ; les vider rouvre au public.
SITE_USER=ton-identifiant
SITE_PASS=ton-mot-de-passe

# Mot de passe du compte super-admin (super@palova.fr). À définir AVANT `npm run db:seed` en prod.
SUPERADMIN_PASSWORD=

# Envoi d'email (validation d'inscription par code, notifications, diffusions club). Sans
# SMTP_HOST, le code n'est PAS envoyé (fallback console) → À RENSEIGNER EN PROD.
# Provider : Brevo (smtp-relay.brevo.com:587). Créer un compte sur brevo.com, vérifier le
# domaine d'envoi (Brevo > Expéditeurs & IP > Domaines → ajouter les enregistrements SPF/DKIM
# dans la zone DNS OVH de palova.fr), puis récupérer les identifiants SMTP dans
# Brevo > SMTP & API > SMTP : SMTP_USER = login SMTP (PAS le mot de passe du compte),
# SMTP_PASS = la clé SMTP générée (pas le mot de passe du compte non plus).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Palova <noreply@palova.fr>"

# Web Push (VAPID) — notifications push navigateur/Android. SANS ces 3 variables, le push
# est INACTIF (l'app ne peut même pas créer d'abonnement) → seuls les emails partent.
# Générer une paire UNE FOIS puis NE PLUS la changer (toute rotation invalide les
# abonnements existants) :  cd backend && npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@palova.fr

# Stripe Connect (paiement en ligne). Valeurs LIVE (pk_live_/sk_live_/whsec_) en prod.
#  - STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET : lues au runtime par le backend.
#  - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY : injectée en BUILD-ARG du frontend → GELÉE au build,
#    donc tout changement impose un rebuild du front (pas un simple `up -d`).
#  - whsec_ : dashboard Stripe → Developers → Webhooks → destination (scope « Connected accounts »).
#  - Rappel : doubler tout `$` en `$$` dans ce fichier (interpolation docker-compose).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook Stripe BILLING (abonnements SaaS des clubs) — endpoint DÉDIÉ, distinct du
# webhook Connect ci-dessus : https://api.palova.fr/api/billing/webhooks
# Événements : checkout.session.completed, customer.subscription.updated/deleted,
# invoice.paid, invoice.payment_failed (scope « Your account », PAS Connected accounts).
STRIPE_BILLING_WEBHOOK_SECRET=

# URL publique de l'API backend, utilisée pour construire les liens absolus DANS les emails
# (ex. désinscription en un clic des emails de diffusion club.broadcast). Sans elle, repli
# http://localhost:3001 (cassé en prod) → à renseigner : https://api.palova.fr
API_PUBLIC_URL=https://api.palova.fr

# --- Support club → Palova (issues GitHub) ---
# Fine-grained PAT scopé au SEUL repo palova-support, permission Issues: Read & write.
# TOKEN/REPO absents → mode console (dev) : le ticket est loggé, pas d'issue ni d'email.
# SUPPORT_FALLBACK_EMAIL = destinataire du repli quand GitHub est configuré mais en échec.
GITHUB_SUPPORT_TOKEN=
GITHUB_SUPPORT_REPO=enouga/palova-support
SUPPORT_FALLBACK_EMAIL=contact@palova.fr

# --- Sauvegardes (deploy/backup-db.sh) ---
# Toutes VIDES par défaut : le pg_dump quotidien + rotation tournent sans elles.
# On remplit une variable pour ACTIVER l'option (rien à décommenter dans le script).
# Cf. docs/sauvegardes.md §3. NB : pas de caractère `$` dans ces valeurs (ce fichier
# est aussi lu par docker-compose, qui interpréterait un `$`).
#
# Supervision dead-man's-switch healthchecks.io : URL de ping du check (le script
# pinge automatiquement /start au début, la base à la réussite, /fail à l'échec).
# Vide → pas de supervision (les sauvegardes tournent quand même).
HC_PING_URL=
#
# Copie hors-site (le « 1 » du 3-2-1) — À REMPLIR quand la destination sera choisie.
# Renseigner UNE seule des deux (scp prioritaire sur rclone) :
#  - Storage Box Hetzner (scp) : OFFSITE_SCP_DEST=uXXXXXX@uXXXXXX.your-storagebox.de:backups/
#    (port 23 par défaut, surchargeable via OFFSITE_SCP_PORT)
#  - S3/B2/Scaleway via rclone préconfiguré : OFFSITE_RCLONE_REMOTE=remote:palova-backups/
# Les deux vides → aucune copie hors-site (dump conservé localement seulement).
OFFSITE_SCP_DEST=
OFFSITE_SCP_PORT=23
OFFSITE_RCLONE_REMOTE=
#
# Chiffrement avant l'envoi hors-site (age) : clé PUBLIQUE du destinataire (age1...).
# La clé PRIVÉE vit au coffre (jamais sur la VM). Vide → dumps envoyés en clair.
# ⚠️ perdre la clé privée = dumps hors-site illisibles → à n'activer qu'une fois la clé sauvegardée.
AGE_RECIPIENT=

# --- Observabilité (GlitchTip, protocole Sentry) ---
# DSN backend (projet « palova-backend » dans GlitchTip). Absent → capture inactive.
GLITCHTIP_DSN=
# DSN frontend (projet « palova-frontend »). NEXT_PUBLIC_* → GELÉE au build : un changement
# impose un rebuild du front. Absent → capture front inactive.
NEXT_PUBLIC_GLITCHTIP_DSN=

# --- Mesure d'audience (Google Analytics 4) ---
# ID de mesure GA4 (G-XXXXXXXX), créé sur analytics.google.com. Injecté en BUILD-ARG du
# frontend → GELÉ au build (rebuild du front si changé). Absent → GA désactivé, aucune
# bannière cookie. GA n'est chargé qu'après consentement explicite du visiteur.
NEXT_PUBLIC_GA_ID=
