# Secrets de production — copier ce fichier en `.env.prod` (NON versionné) et remplir.
# Utilisé par docker-compose.prod.yml :
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# Mot de passe de la base Postgres (choisis une chaîne forte).
POSTGRES_PASSWORD=change-moi-mot-de-passe-postgres-fort

# Clé de signature des JWT (longue chaîne aléatoire).
# Générer p.ex. avec :  openssl rand -hex 48
JWT_SECRET=change-moi-longue-chaine-aleatoire

# Verrou d'accès privé (Basic Auth) — pop-up login sur tout le site.
# Laisser ces 2 variables pour garder le site privé ; les vider rouvre au public.
SITE_USER=ton-identifiant
SITE_PASS=ton-mot-de-passe

# Mot de passe du compte super-admin (super@palova.fr). À définir AVANT `npm run db:seed` en prod.
SUPERADMIN_PASSWORD=
